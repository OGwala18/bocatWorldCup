CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LIVE_STATE_PATH=

# Point this at a live football fixtures/results API endpoint when you are ready.
# The adapter accepts common payload shapes with fixtures/matches/response/data arrays.
LIVE_MATCHES_PROVIDER=api-football
LIVE_MATCHES_API_URL=https://v3.football.api-sports.io/fixtures?league=1&season=2026&timezone=Africa/Johannesburg
LIVE_MATCHES_API_KEY=
LIVE_MATCHES_API_KEY_HEADER=x-apisports-key
LIVE_MATCHES_EXTRA_HEADERS=

# RapidAPI API-Football alternative:
# LIVE_MATCHES_API_URL=https://api-football-v1.p.rapidapi.com/v3/fixtures?league=1&season=2026&timezone=Africa/Johannesburg
# LIVE_MATCHES_API_KEY_HEADER=x-rapidapi-key
# LIVE_MATCHES_EXTRA_HEADERS=x-rapidapi-host=api-football-v1.p.rapidapi.com

# No-key ESPN scoreboard fallback. Run sync-scores every 10 minutes during the tournament.
# It checks matches from kickoff until 180 minutes after kickoff, then keeps retrying
# old unfinished matches until ESPN marks them completed.
FALLBACK_SCORES_PROVIDER=espn
FALLBACK_SCORES_URL_TEMPLATE=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard?dates={date}
QUALIFICATION_STANDINGS_URL=https://site.web.api.espn.com/apis/v2/sports/soccer/fifa.world/standings?season=2026
POST_MATCH_DELAY_MINUTES=120
SCORE_POLL_START_MINUTES_BEFORE_KICKOFF=0
SCORE_POLL_END_MINUTES_AFTER_KICKOFF=180
SCORE_POLL_INTERVAL_MINUTES=10
ENABLE_SCORE_POLLING=true

# For Vite builds where the API is hosted separately:
VITE_API_BASE=
